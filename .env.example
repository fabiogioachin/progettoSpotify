# Spotify OAuth credentials
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8001/auth/spotify/callback

# Session security — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# Encryption salt — use a unique value per deployment
ENCRYPTION_SALT=your_unique_salt_here

# Frontend/Backend URLs
FRONTEND_URL=http://127.0.0.1:5173
BACKEND_URL=http://127.0.0.1:8001

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://spotify:spotify_dev@localhost:5432/spotify_intelligence

# Redis
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development

# Set to True in production (requires HTTPS)
COOKIE_SECURE=False
